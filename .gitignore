node_modules

# PDFs (served from R2)
PDFs/

# Generated per-slug reading markdown (run `node scripts/generate-readings.js`
# or `npm run build` to regenerate; served as static assets at /reading-content/...)
static/reading-content/
static/readings-fallback.json

# Generated semantic-search index (run `node scripts/embed-readings.js` to
# regenerate after corpus changes; served at /embeddings.bin + /embeddings-meta.json)
static/embeddings.bin
static/embeddings-meta.json

# PDF pipeline scratch (per-PDF metadata, page renders, raw OCR, VLM outputs)
work/

# (Figures extracted from PDFs are staged under work/<slug>/figures/ — see
# scripts/pdf-pipeline/figures.js — and uploaded to R2 by upload-figures.sh.
# They never enter static/, so the Worker deploy doesn't ship duplicates.)

